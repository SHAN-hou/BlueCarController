<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- Status Bar -->
    <LinearLayout
        android:id="@+id/statusBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="#16213E"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="蓝牙小车控制器"
            android:textColor="#E94560"
            android:textSize="20sp"
            android:textStyle="bold" />

        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/dot_red" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="未连接"
            android:textColor="#8899AA"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bluetooth Connect Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConnect"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="连接蓝牙"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        app:backgroundTint="#0F3460"
        app:cornerRadius="28dp"
        app:icon="@android:drawable/stat_sys_data_bluetooth"
        app:iconGravity="textStart"
        app:iconTint="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/statusBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Speed Display -->
    <TextView
        android:id="@+id/tvCommand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="待命"
        android:textColor="#53BF9D"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnConnect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Direction Pad Container -->
    <FrameLayout
        android:id="@+id/dpadContainer"
        android:layout_width="300dp"
        android:layout_height="300dp"
        app:layout_constraintTop_toBottomOf="@id/tvCommand"
        app:layout_constraintBottom_toTopOf="@id/logScroll"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Forward Button (Top) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnForward"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="top|center_horizontal"
            android:text="▲\n前进"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:lineSpacingExtra="-2dp"
            app:backgroundTint="#0F3460"
            app:cornerRadius="16dp" />

        <!-- Left Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLeft"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center_vertical|start"
            android:text="◀\n左转"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:lineSpacingExtra="-2dp"
            app:backgroundTint="#0F3460"
            app:cornerRadius="16dp" />

        <!-- Stop Button (Center) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStop"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center"
            android:text="■\n停止"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:lineSpacingExtra="-2dp"
            app:backgroundTint="#E94560"
            app:cornerRadius="45dp" />

        <!-- Right Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRight"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="center_vertical|end"
            android:text="▶\n右转"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:lineSpacingExtra="-2dp"
            app:backgroundTint="#0F3460"
            app:cornerRadius="16dp" />

        <!-- Backward Button (Bottom) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackward"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_gravity="bottom|center_horizontal"
            android:text="▼\n后退"
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:lineSpacingExtra="-2dp"
            app:backgroundTint="#0F3460"
            app:cornerRadius="16dp" />
    </FrameLayout>

    <!-- Log Area -->
    <ScrollView
        android:id="@+id/logScroll"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_margin="16dp"
        android:background="#16213E"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待连接..."
            android:textColor="#556677"
            android:textSize="12sp"
            android:fontFamily="monospace" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
